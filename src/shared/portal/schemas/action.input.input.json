{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["selector", "value"],
  "properties": {
    "selector": {
      "type": "string",
      "description": "CSS selector of the input element"
    },
    "value": {
      "type": "string",
      "description": "Text value to input"
    }
  }
}
